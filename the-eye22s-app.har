            "mimeType": "text/css",
            "text": ".Sidebar-module__XRNO5a__sidebar{background-color:var(--bg-secondary);border-right:1px solid var(--border-subtle);flex-direction:column;width:100%;height:100%;padding:24px 16px;display:flex;overflow:hidden}.Sidebar-module__XRNO5a__newChatBtn{background-color:var(--accent-primary);width:100%;color:var(--bg-primary);border-radius:var(--radius-md);cursor:pointer;box-shadow:var(--shadow-sm);transition:var(--transition-main);border:none;align-items:center;gap:12px;margin-bottom:40px;padding:14px 24px;font-weight:700;display:flex}.Sidebar-module__XRNO5a__newChatBtn:hover{box-shadow:var(--shadow-md);opacity:.9;transform:translateY(-2px)}.Sidebar-module__XRNO5a__itemIcon .icon-filled{opacity:0;transition:opacity var(--transition-main);position:absolute;inset:0}.Sidebar-module__XRNO5a__itemIcon .icon-outline{opacity:1;transition:opacity var(--transition-main)}.Sidebar-module__XRNO5a__item:hover .Sidebar-module__XRNO5a__itemIcon .icon-filled{opacity:1}.Sidebar-module__XRNO5a__itemActive .Sidebar-module__XRNO5a__itemIcon .icon-filled{opacity:1}.Sidebar-module__XRNO5a__item:hover .Sidebar-module__XRNO5a__itemIcon .icon-outline{opacity:0}.Sidebar-module__XRNO5a__itemActive .Sidebar-module__XRNO5a__itemIcon .icon-outline{opacity:0}.Sidebar-module__XRNO5a__section{flex-direction:column;gap:20px;display:flex}.Sidebar-module__XRNO5a__sectionTitle{text-transform:uppercase;color:var(--text-secondary);letter-spacing:2px;margin-bottom:16px;padding-left:12px;font-size:10px;font-weight:800}.Sidebar-module__XRNO5a__item{cursor:pointer;color:var(--text-secondary);border-radius:var(--radius-md);transition:var(--transition-main);background-color:#0000;border:1px solid #0000;align-items:center;gap:14px;padding:12px 14px;display:flex;position:relative}.Sidebar-module__XRNO5a__item:hover{background-color:var(--bg-card);color:var(--text-primary);box-shadow:var(--shadow-md);border:1px solid var(--border-primary);z-index:10;transform:translateY(-2px)}.Sidebar-module__XRNO5a__itemActive{background-color:var(--bg-card);color:var(--text-primary);border:1px solid var(--accent-primary);box-shadow:var(--shadow-sm)}.Sidebar-module__XRNO5a__itemIcon{justify-content:center;align-items:center;width:20px;height:20px;display:flex;position:relative}.Sidebar-module__XRNO5a__itemMain{flex-direction:column;display:flex}.Sidebar-module__XRNO5a__itemLabel{font-size:14px;font-weight:700}.Sidebar-module__XRNO5a__itemDesc{color:var(--text-secondary);font-size:11px;font-weight:500}.Sidebar-module__XRNO5a__footer{margin-top:auto;padding-top:24px}.Sidebar-module__XRNO5a__readinessCard{background:var(--bg-secondary);border-radius:var(--radius-lg);border:1px solid var(--border-subtle);cursor:pointer;transition:var(--transition-main);padding:16px}.Sidebar-module__XRNO5a__readinessCard:hover{background:var(--bg-card);border-color:var(--border-primary);box-shadow:var(--shadow-lg);transform:translateY(-4px)}.Sidebar-module__XRNO5a__readinessHeader{align-items:center;gap:8px;margin-bottom:16px;display:flex}.Sidebar-module__XRNO5a__readinessTitle{color:var(--text-secondary);letter-spacing:1.5px;font-size:9px;font-weight:800}.Sidebar-module__XRNO5a__readinessContent{align-items:center;gap:16px;display:flex}.Sidebar-module__XRNO5a__gaugeWrapper{width:50px;height:50px}.Sidebar-module__XRNO5a__gaugeBg{fill:none;stroke:var(--bg-secondary);stroke-width:8px}.Sidebar-module__XRNO5a__gaugeFill{fill:none;stroke:var(--accent-green);stroke-width:8px;stroke-linecap:round;transform-origin:50%;transition:stroke-dashoffset .8s;transform:rotate(-90deg)}.Sidebar-module__XRNO5a__gaugeText{fill:var(--text-primary);font-size:22px;font-weight:800}.Sidebar-module__XRNO5a__readinessInfo{flex-direction:column;gap:2px;display:flex}.Sidebar-module__XRNO5a__platformsCount{color:var(--text-primary);font-size:13px;font-weight:700}.Sidebar-module__XRNO5a__reliabilityLabel{color:var(--text-secondary);font-size:11px}.Sidebar-module__XRNO5a__reliabilityHigh{color:var(--accent-green);font-weight:800}\n"
