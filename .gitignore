# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# scratch
/scratch

.vercel
.env*.local

# agent metadata
/.gemini

# logs
server.log
*.log

# generated / one-off data files
models.json
*.csv

# binary office docs (keep in docs/ folder outside git if needed)
*.pptx
*.docx
*.pdf

# python
__pycache__/
*.pyc
# Sentry Config File
.env.sentry-build-plugin
